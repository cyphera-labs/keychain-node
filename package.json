{
  "name": "@cyphera/keychain",
  "version": "0.1.0",
  "description": "Key provider abstraction for Cyphera encryption SDKs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='src/__tests__/(?!integration)'"
  },
  "keywords": [
    "cyphera",
    "encryption",
    "key-management",
    "fpe"
  ],
  "author": "Cyphera <sdk@cyphera.dev>",
  "license": "MIT",
  "devDependencies": {
    "@aws-sdk/client-kms": "^3.1029.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-keys": "^4.8.0",
    "@google-cloud/kms": "^5.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-kms": ">=3",
    "@azure/identity": ">=4",
    "@azure/keyvault-keys": ">=4",
    "@google-cloud/kms": ">=4"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-kms": {
      "optional": true
    },
    "@google-cloud/kms": {
      "optional": true
    },
    "@azure/keyvault-keys": {
